# Committed defaults for local development. Real secrets go in .env.local (gitignored).
# Postgres (Vercel Postgres / Neon). Set the real values in .env.local — locally
# point both at your cloud Postgres connection string. On Vercel, DATABASE_URL is
# auto-injected by Vercel Postgres; add DIRECT_URL = the non-pooling URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Session signing secret — override in production!
SESSION_SECRET="saarthi-dev-secret-change-me-in-production"

# Anthropic API (AI parsing, chat, qualifier bot). Leave empty to run in
# heuristic fallback mode — everything still works, just without the AI smarts.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"

# WhatsApp Business Cloud API (Meta). Leave empty in dev — outbound messages
# are logged to console instead, and the admin Simulator works without it.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="saarthi-verify"

# Voice-note transcription for the admin "Add lead" feature. Any OpenAI-compatible
# /audio/transcriptions endpoint (OpenAI, Groq, etc.). Empty = voice disabled,
# staff type the note instead.
TRANSCRIPTION_API_KEY=""
TRANSCRIPTION_BASE_URL="https://api.openai.com/v1"
TRANSCRIPTION_MODEL="whisper-1"

# Secret guarding the automations cron endpoint. Set in production; the local
# scheduler reads the same value. Empty = endpoint open (local dev only).
CRON_SECRET=""

# Public-facing config
NEXT_PUBLIC_WHATSAPP_NUMBER="919826078459"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seed admin credentials (used by prisma/seed.ts)
SEED_ADMIN_PHONE="919826078459"
SEED_ADMIN_PASSWORD="saarthi123"
